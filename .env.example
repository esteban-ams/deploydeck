# Environment variables for FastShip
# Copy this to .env and customize

# Override config file location
# FASTSHIP_CONFIG=/path/to/config.yaml

# Override server settings
# FASTSHIP_PORT=9000
# FASTSHIP_HOST=0.0.0.0

# Override webhook secret
# FASTSHIP_WEBHOOK_SECRET=your-secret-here

# Override logging
# FASTSHIP_LOG_LEVEL=info

# Clone token for private repos (build mode)
# Falls back when clone_token and clone_token_file are not set
# FASTSHIP_CLONE_TOKEN=your-github-or-gitlab-token
