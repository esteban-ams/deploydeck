# Environment variables for DeployDeck
# Copy this to .env and customize

# Override config file location
# DEPLOYDECK_CONFIG=/path/to/config.yaml

# Override server settings
# DEPLOYDECK_PORT=9000
# DEPLOYDECK_HOST=0.0.0.0

# Override webhook secret
# DEPLOYDECK_WEBHOOK_SECRET=your-secret-here

# Override logging
# DEPLOYDECK_LOG_LEVEL=info

# Clone token for private repos (build mode)
# Falls back when clone_token and clone_token_file are not set
# DEPLOYDECK_CLONE_TOKEN=your-github-or-gitlab-token
